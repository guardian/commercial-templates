{
	"name": "@guardian/commercial-templates-builder",
	"version": "0.0.1",
	"license": "Apache-2.0",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"prepare": "husky && svelte-kit sync",
		"dev": "vite dev --port 7777",
		"build:preview": "vite build && touch build/.nojekyll",
		"build:template:capi-multiple-hosted": "BUILD_TEMPLATE=capi-multiple-hosted REPLACE_GAM_VARS=true vite build",
		"build:template:capi-multiple-paidfor": "BUILD_TEMPLATE=capi-multiple-paidfor REPLACE_GAM_VARS=true vite build",
		"build:template:capi-single-paidfor": "BUILD_TEMPLATE=capi-single-paidfor REPLACE_GAM_VARS=true vite build",
		"build:template:events-multiple": "BUILD_TEMPLATE=events-multiple REPLACE_GAM_VARS=true vite build",
		"build:template:fabric": "BUILD_TEMPLATE=fabric REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-custom": "BUILD_TEMPLATE=fabric-custom REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-custom-xl": "BUILD_TEMPLATE=fabric-custom-xl REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-expandable": "BUILD_TEMPLATE=fabric-expandable REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-video": "BUILD_TEMPLATE=fabric-video REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-video-xl": "BUILD_TEMPLATE=fabric-video-xl REPLACE_GAM_VARS=true vite build",
		"build:template:fabric-xl": "BUILD_TEMPLATE=fabric-xl REPLACE_GAM_VARS=true vite build",
		"build:template:interscroller": "BUILD_TEMPLATE=interscroller REPLACE_GAM_VARS=true vite build",
		"build:template:manual-multiple": "BUILD_TEMPLATE=manual-multiple REPLACE_GAM_VARS=true vite build",
		"build:template:manual-single": "BUILD_TEMPLATE=manual-single REPLACE_GAM_VARS=true vite build",
		"build:template:mobile-revealer": "BUILD_TEMPLATE=mobile-revealer REPLACE_GAM_VARS=true vite build",
		"build:template:public-good": "BUILD_TEMPLATE=public-good REPLACE_GAM_VARS=true vite build",
		"build:template:public-good-test": "BUILD_TEMPLATE=public-good-test REPLACE_GAM_VARS=true vite build",
		"build:templates": "pnpm run /^build:template:.*/",
		"publish": "pnpm gh-pages --dist build --dotfiles",
		"deploy": "pnpm build && pnpm publish",
		"package": "svelte-kit package",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "pnpm eslint:check && pnpm prettier:check",
		"format": "pnpm eslint:fix && pnpm prettier:fix",
		"test:vite-plugins": "vitest run vite/*.test.ts",
		"eslint:check": "eslint .",
		"eslint:fix": "eslint . --fix",
		"prettier:check": "prettier --check .",
		"prettier:fix": "prettier --write ."
	},
	"devDependencies": {
		"@guardian/eslint-config": "^14.0.1",
		"@guardian/prettier": "^10.0.0",
		"@guardian/source": "12.2.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@types/eslint": "^9.6.1",
		"@types/jsdom": "^27.0.0",
		"eslint": "^9.39.4",
		"eslint-plugin-svelte": "^3.16.0",
		"gh-pages": "^6.3.0",
		"globals": "^16.5.0",
		"google-auth-library": "^10.6.1",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"marked": "^11.2.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.97.3",
		"superstruct": "^2.0.2",
		"svelte": "^4.2.20",
		"svelte-check": "^3.8.6",
		"svelte-preprocess": "^6.0.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^5.4.21",
		"vitest": "^4.0.18"
	},
	"type": "module",
	"packageManager": "pnpm@10.14.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"svelte-preprocess"
		],
		"overrides": {
			"flatted@<=3.4.1": ">=3.4.2"
		}
	}
}
